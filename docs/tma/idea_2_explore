## 🔌 Backend: InsForge Integration

Since you're using InsForge, we get these for FREE:

### InsForge Provides:

| Feature | How It Helps Deal Quest |
|---------|------------------------|
| **PostgreSQL** | Users, attempts, casebook, teams |
| **Authentication** | Telegram auth flow, JWT sessions |
| **Realtime** | Live leaderboard updates |
| **Storage** | Badge images, case attachments |
| **Functions** | LLM orchestration, scoring |
| **AI Integration** | Built-in Claude/OpenAI support |

### Database Schema (InsForge Tables)

```sql
-- Users (synced from Telegram)
CREATE TABLE users (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    telegram_id BIGINT UNIQUE NOT NULL,
    username TEXT,
    first_name TEXT,
    avatar_url TEXT,
    
    -- Progress
    xp INTEGER DEFAULT 0,
    level INTEGER DEFAULT 1,
    current_track INTEGER DEFAULT 1,
    
    -- Team
    team_id UUID REFERENCES teams(id),
    role TEXT DEFAULT 'member',  -- 'member', 'manager', 'admin'
    
    -- Settings
    llm_provider TEXT DEFAULT 'openrouter',
    preferences JSONB DEFAULT '{}',
    
    created_at TIMESTAMPTZ DEFAULT NOW(),
    updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- Teams (Company/Group)
CREATE TABLE teams (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name TEXT NOT NULL,
    company TEXT,
    logo_url TEXT,
    settings JSONB DEFAULT '{}',
    created_at TIMESTAMPTZ DEFAULT NOW()
);

-- Badges
CREATE TABLE badges (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name TEXT NOT NULL,
    description TEXT,
    icon_url TEXT,
    criteria JSONB,  -- {"type": "xp", "threshold": 1000}
    rarity TEXT DEFAULT 'common'  -- 'common', 'rare', 'epic', 'legendary'
);

-- User Badges (earned)
CREATE TABLE user_badges (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID REFERENCES users(id),
    badge_id UUID REFERENCES badges(id),
    earned_at TIMESTAMPTZ DEFAULT NOW(),
    UNIQUE(user_id, badge_id)
);

-- Scenario Attempts
CREATE TABLE attempts (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID REFERENCES users(id),
    scenario_id TEXT NOT NULL,
    mode TEXT NOT NULL,  -- 'learn', 'train'
    user_response TEXT NOT NULL,
    score INTEGER NOT NULL,
    feedback JSONB,
    xp_earned INTEGER NOT NULL,
    time_taken_seconds INTEGER,
    created_at TIMESTAMPTZ DEFAULT NOW()
);

-- Casebook (reusable responses)
CREATE TABLE casebook (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    persona_type TEXT NOT NULL,
    scenario_type TEXT NOT NULL,
    industry TEXT,
    seniority TEXT,
    prospect_analysis TEXT,
    closing_strategy TEXT,
    engagement_tactics TEXT,
    draft_response TEXT,
    quality_score REAL DEFAULT 0.5,
    times_used INTEGER DEFAULT 0,
    created_by UUID REFERENCES users(id),
    created_at TIMESTAMPTZ DEFAULT NOW()
);

-- Support Sessions
CREATE TABLE support_sessions (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID REFERENCES users(id),
    input_type TEXT,  -- 'text', 'image', 'voice'
    context_text TEXT,
    prospect_analysis JSONB,
    closing_strategy JSONB,
    draft_response TEXT,
    feedback TEXT,  -- 'positive', 'negative', 'neutral'
    casebook_added BOOLEAN DEFAULT FALSE,
    created_at TIMESTAMPTZ DEFAULT NOW()
);

-- Leaderboard (materialized view, refreshed hourly)
CREATE MATERIALIZED VIEW leaderboard AS
SELECT 
    u.id,
    u.telegram_id,
    u.username,
    u.first_name,
    u.avatar_url,
    u.xp,
    u.team_id,
    t.name as team_name,
    RANK() OVER (ORDER BY u.xp DESC) as global_rank,
    RANK() OVER (PARTITION BY u.team_id ORDER BY u.xp DESC) as team_rank
FROM users u
LEFT JOIN teams t ON u.team_id = t.id
WHERE u.xp > 0;
```

